PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/ai-roast
SESSION_SECRET=change_this_session_secret
RESET_SECRET=change_this_reset_secret
GEMINI_API_KEY=your_gemini_api_key

# Local development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Production example (Render backend + Netlify frontend):
# NODE_ENV=production
# FRONTEND_URL=https://famous-gecko-566278.netlify.app
# CORS_ORIGINS=https://famous-gecko-566278.netlify.app
# ALLOW_NETLIFY_PREVIEWS=true
# TRUST_PROXY=true
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false
ALLOW_NETLIFY_PREVIEWS=false

EMAIL_SERVICE=gmail
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=your_email@example.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=ai-roast

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=optional_webhook_secret
